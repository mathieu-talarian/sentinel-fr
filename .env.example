# Sentinel backend base URL — proxied at /chat, /classify, /api-doc
# Defaults to https://127.0.0.1:8888 (the Rust server's rustls default).
VITE_SENTINEL_API_BASE=https://127.0.0.1:8888

# Provider hint forwarded with every chat request (optional)
# VITE_SENTINEL_PROVIDER=anthropic

# --- Sentry ---------------------------------------------------------------
# Public DSN (browser-side). Leave empty to disable Sentry entirely.
# VITE_SENTRY_DSN=

# Optional release identifier (e.g. git SHA). Forwarded to both the runtime
# SDK (so events are tagged) and the Vite source-map upload plugin.
# VITE_APP_RELEASE=

# Sample rates (0..1). Defaults: traces 1.0 dev / 0.2 prod, replay session
# 0 dev / 0.1 prod, replay-on-error 1.0.
# VITE_SENTRY_TRACES_SAMPLE_RATE=
# VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=
# VITE_SENTRY_REPLAY_ERROR_SAMPLE_RATE=

# Source-map upload (build-time only — never exposed to the browser). All
# three must be set for `@sentry/vite-plugin` to engage; missing any one
# disables the plugin and skips map upload.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
